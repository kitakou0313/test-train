// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/python
{
	"name": "Python 3",
	// Or use a Dockerfile or Docker Compose file. More info: https://containers.dev/guide/dockerfile
	"image": "mcr.microsoft.com/devcontainers/python:3-3.14-trixie",
	"features": {
		"ghcr.io/devcontainers/features/git:1": {},
		"ghcr.io/duduribeiro/devcontainer-features/tmux:1": {},
		"ghcr.io/siri404/devcontainer-ai-features/claude-code:1": {}
	},

	// Features to add to the dev container. More info: https://containers.dev/features.
	// "features": {},

	"forwardPorts": [8000],
	"portsAttributes": {
		"8000": {
			"label": "FastAPI App",
			"onAutoForward": "openPreview"
		}
	},
	"postCreateCommand": "pip3 install -r requirements-dev.txt && playwright install chromium --with-deps",
	"customizations": {
		"vscode": {
			"extensions": [
				"ms-python.python",
				"ms-python.vscode-pylance",
				"ms-playwright.playwright",
				"bierner.markdown-mermaid"
			],
			"settings": {
				"python.defaultInterpreterPath": "/usr/local/bin/python3",
				"python.testing.pytestEnabled": true,
				"python.testing.pytestArgs": ["tests"]
			}
		}
	},
	"containerEnv": {
		"TZ": "Asia/Tokyo",
		"DATABASE_URL": "sqlite:///./taskdb.sqlite3",
		"APP_ENV": "development"
	}
}
